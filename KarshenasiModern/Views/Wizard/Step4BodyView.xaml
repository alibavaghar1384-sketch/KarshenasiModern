<UserControl x:Class="KarshenasiModern.Views.Wizard.Step4BodyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:KarshenasiModern.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style x:Key="CarPartButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <TextBlock Text="{TemplateBinding Content}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center"
                                       FontSize="12"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C61E7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="15,15,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <TextBlock Text="گزارش وضعیت بدنه، شاسی و رنگ خودرو" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                <TextBlock Text="مرحله ۴ از ۵" FontSize="12" Foreground="#64748B" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="لیست قطعات بدنه" FontSize="14" FontWeight="Bold" Foreground="#475569" Margin="5,5,5,12"/>
                        <UniformGrid Columns="2">
                            <Button Content="سپر جلو" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_FrontBumper"/>
                            <Button Content="کاپوت" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_Hood"/>
                            <Button Content="سقف" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_Roof"/>
                            <Button Content="صندوق عقب" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_Trunk"/>
                            <Button Content="سپر عقب" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_RearBumper"/>
                            <Button Content="درب جلو راننده" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_FLDoor"/>
                            <Button Content="درب جلو شاگرد" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_FRDoor"/>
                            <Button Content="درب عقب راننده" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_RLDoor"/>
                            <Button Content="درب عقب شاگرد" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_RRDoor"/>
                            <Button Content="گلگیر جلو راننده" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_FLFender"/>
                            <Button Content="گلگیر جلو شاگرد" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_FRFender"/>
                            <Button Content="گلگیر عقب راننده" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_RLFender"/>
                            <Button Content="گلگیر عقب شاگرد" Style="{StaticResource CarPartButtonStyle}" Click="PartButton_Click" x:Name="Btn_RRFender"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10">
                    <controls:CarBodyDiagram x:Name="CarDiagram"/>
                </Border>

                <Popup x:Name="PartActionPopup" Placement="Center" AllowsTransparency="True" StaysOpen="False">
                    <Border Background="White" Width="320" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
                        </Border.Effect>
                        <StackPanel Margin="20">
                            <TextBlock x:Name="PopupPartNameText" Text="نام قطعه" FontSize="18" FontWeight="Bold" Foreground="#1C61E7" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                            <TextBlock Text="وضعیت قطعه:" Margin="0,0,0,5" Foreground="#555555" FontSize="12"/>
                            <ComboBox x:Name="PopupStatusCombo" Height="35" DisplayMemberPath="Title" SelectedValuePath="Value" Margin="0,0,0,15"/>

                            <TextBlock Text="ضخامت رنگ (میکرون):" Margin="0,0,0,5" Foreground="#555555" FontSize="12"/>
                            <TextBox x:Name="PopupThicknessText" Height="35" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,25" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="انصراف" Click="ClosePopup_Click" Grid.Column="0" Margin="0,0,5,0" Height="40" Background="#F0F4F8" BorderBrush="#D1D9E6"/>
                                <Button Content="تایید و ثبت" Click="SavePart_Click" Grid.Column="1" Margin="5,0,0,0" Height="40" Background="#1C61E7" Foreground="White"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="12" Margin="15,0,15,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Button x:Name="BackButton" Content="مرحله قبل" HorizontalAlignment="Right" Width="120" Height="38" Background="#F1F5F9" BorderThickness="0"/>
                <Button x:Name="NextButton" Content="ثبت و مرحله بعد" HorizontalAlignment="Left" Width="140" Height="38" Background="#1C61E7" Foreground="White" BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>