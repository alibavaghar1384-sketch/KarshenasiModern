<Window x:Class="KarshenasiModern.Views.Wizard.InspectionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="کارشناسی جدید"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#F5F7FA">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Step Bar -->

        <Border Background="White"
                Margin="15"
                CornerRadius="12">

            <UniformGrid Columns="5">

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Step1Text"
                               Text="اطلاعات مشتری"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Step2Text"
                               Text="اطلاعات کارشناسی"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Step3Text"
                               Text="عکسبرداری"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Step4Text"
                               Text="بدنه خودرو"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Step5Text"
                               Text="پیش نمایش"/>
                </StackPanel>

            </UniformGrid>

        </Border>

        <!-- Content -->

        <Border Grid.Row="1"
                Margin="15,0,15,15"
                Background="White"
                CornerRadius="12">

            <ContentControl
                x:Name="WizardContent"/>

        </Border>

    </Grid>

</Window>