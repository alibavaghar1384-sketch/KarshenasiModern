<UserControl x:Class="KarshenasiModern.Views.Wizard.Step2InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#F5F6FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="30">

            <StackPanel>

                <TextBlock Text="اطلاعات فنی و کارشناسی"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,25"
                           Foreground="#1C61E7"/>

                <UniformGrid Columns="2">

                    <StackPanel Margin="10">
                        <TextBlock Text="کارکرد (کیلومتر)" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="MileageTextBox"
                                 Height="45"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"/>
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="وضعیت موتور" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="EngineStatusCombo"
                                  Height="45"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="سالم"/>
                            <ComboBoxItem Content="نیاز به بررسی"/>
                            <ComboBoxItem Content="دارای ایراد"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="وضعیت گیربکس" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="GearboxStatusCombo"
                                  Height="45"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="سالم"/>
                            <ComboBoxItem Content="نیاز به بررسی"/>
                            <ComboBoxItem Content="دارای ایراد"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="وضعیت شاسی" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ChassisStatusCombo"
                                  Height="45"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="سالم"/>
                            <ComboBoxItem Content="آسیب دیده"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="10">
                        <TextBlock Text="وضعیت ایربگ" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="AirbagStatusCombo"
                                  Height="45"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="سالم"/>
                            <ComboBoxItem Content="خطا دارد"/>
                        </ComboBox>
                    </StackPanel>

                </UniformGrid>

                <TextBlock Text="توضیحات کارشناس"
                           Margin="10,20,10,5"
                           FontWeight="Bold"
                           FontSize="14"/>

                <TextBox x:Name="DescriptionTextBox"
                         Height="150"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Margin="10"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch"
                         VerticalContentAlignment="Top"/>

                <StackPanel Orientation="Horizontal"
                            Margin="10,25,0,0">

                    <Button x:Name="BackButton"
                            Content="مرحله قبل"
                            Width="180"
                            Height="50"
                            Margin="0,0,10,0"
                            Background="#E0E0E0"
                            BorderThickness="0"
                            FontWeight="Bold"/>

                    <Button x:Name="NextButton"
                            Content="عکسبرداری"
                            Width="180"
                            Height="50"
                            Background="#1C61E7"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </ScrollViewer>
</UserControl>