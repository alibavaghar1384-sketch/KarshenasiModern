<UserControl x:Class="KarshenasiModern.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">

            <TextBox x:Name="SearchBox"
                     Width="350"
                     Height="40"
                     Margin="0,0,10,0"/>

            <Button Content="جستجو"
                    Width="120"
                    Height="40"/>
        </StackPanel>

        <DataGrid x:Name="CarsGrid"
                  Grid.Row="1"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="شماره شاسی"
                    Binding="{Binding ChassisNumber}" />

                <DataGridTextColumn
                    Header="پلاک"
                    Binding="{Binding Plate}" />

                <DataGridTextColumn
                    Header="مشتری"
                    Binding="{Binding CustomerName}" />

                <DataGridTextColumn
                    Header="برند"
                    Binding="{Binding Brand}" />

                <DataGridTextColumn
                    Header="مدل"
                    Binding="{Binding Model}" />

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>