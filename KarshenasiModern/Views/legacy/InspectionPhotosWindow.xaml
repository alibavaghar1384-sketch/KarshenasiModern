<Window x:Class="KarshenasiModern.Views.InspectionPhotosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تصاویر کارشناسی"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <UniformGrid Columns="2">

            <Border Margin="5">
                <Image x:Name="FrontImage"
                       Stretch="Uniform"/>
            </Border>

            <Border Margin="5">
                <Image x:Name="RearImage"
                       Stretch="Uniform"/>
            </Border>

            <Border Margin="5">
                <Image x:Name="LeftImage"
                       Stretch="Uniform"/>
            </Border>

            <Border Margin="5">
                <Image x:Name="RightImage"
                       Stretch="Uniform"/>
            </Border>

        </UniformGrid>

    </Grid>

</Window>