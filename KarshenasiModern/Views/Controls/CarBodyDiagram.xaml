<UserControl x:Class="KarshenasiModern.Views.Controls.CarBodyDiagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Border Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="1920" Height="1280" Background="Transparent">

                    <Image Source="pack://application:,,,/KarshenasiModern;component/Assets/Car/car_base.png" 
                           Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="0"/>

                    <Image x:Name="HoodPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RoofPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="TrunkPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>

                    <Image x:Name="FrontLeftFenderPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="FrontLeftDoorPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearLeftDoorPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearLeftFenderPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="LeftSillPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="LeftViewFrontBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="LeftViewRearBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>

                    <Image x:Name="FrontRightFenderPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="FrontRightDoorPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearRightDoorPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearRightFenderPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RightSillPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RightViewFrontBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RightViewRearBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>

                    <Image x:Name="FrontViewBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="FrontViewHoodPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="FrontViewRoofPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearViewRoofPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearViewTrunkPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>
                    <Image x:Name="RearViewBumperPart" Width="1920" Height="1280" Stretch="Fill" Panel.ZIndex="1" Visibility="Collapsed"/>

                </Grid>
            </Viewbox>

            <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0" Padding="15,0,0,0" Margin="15,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="راهنمای وضعیت بدنه" FontSize="14" FontWeight="Bold" Foreground="#1C61E7" Margin="0,5,0,20" HorizontalAlignment="Center"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="Red" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="رنگ شدگی" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="LimeGreen" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="قطعه تعویضی" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="DodgerBlue" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="لیسه / آبرنگ" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="Gold" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="آفتاب سوختگی" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="DarkTurquoise" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="صافکاری بی‌رنگ (PDR)" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="MediumPurple" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="تعمیر شده" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="SaddleBrown" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="خط و خش / غری" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <Border Width="16" Height="16" Background="Gray" CornerRadius="8" Margin="0,0,10,0"/>
                                <TextBlock Text="آسیب دیده / ضربه خورده" FontSize="12" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>