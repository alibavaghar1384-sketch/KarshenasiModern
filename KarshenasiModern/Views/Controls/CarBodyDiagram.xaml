<UserControl x:Class="KarshenasiModern.Views.Controls.CarBodyDiagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:KarshenasiModern.Models"
             xmlns:local="clr-namespace:KarshenasiModern.Views.Controls"
             xmlns:converters="clr-namespace:KarshenasiModern.Views.Converters"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <converters:BodyPartStatusToBrushConverter x:Key="StatusToBrushConverter"/>

        <Style x:Key="CarPartStyle" TargetType="Shape">
            <Setter Property="Fill" Value="#F8FAFC"/>
            <Setter Property="Stroke" Value="#94A3B8"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                    <Setter Property="Stroke" Value="#1C61E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ViewTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="LegendCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <StackPanel Margin="15">
                        <TextBlock Text="نمای بالا" Style="{StaticResource ViewTitleStyle}"/>
                        <Canvas Width="200" Height="400" Background="Transparent">
                            <Path x:Name="FrontBumperPart" Style="{StaticResource CarPartStyle}" Data="M 40,40 Q 100,20 160,40 L 155,60 Q 100,45 45,60 Z"/>
                            <Path x:Name="HoodPart" Style="{StaticResource CarPartStyle}" Data="M 45,65 L 155,65 L 165,130 L 35,130 Z"/>
                            <Path x:Name="RoofPart" Style="{StaticResource CarPartStyle}" Data="M 45,145 L 155,145 L 160,240 L 40,240 Z"/>
                            <Path x:Name="TrunkPart" Style="{StaticResource CarPartStyle}" Data="M 40,255 L 160,255 L 150,320 L 50,320 Z"/>
                            <Path x:Name="RearBumperPart" Style="{StaticResource CarPartStyle}" Data="M 50,325 L 150,325 L 155,345 Q 100,360 45,345 Z"/>

                            <Path x:Name="FrontLeftFenderPart" Style="{StaticResource CarPartStyle}" Data="M 15,65 L 35,65 L 30,120 L 15,110 Z"/>
                            <Path x:Name="FrontLeftDoorPart" Style="{StaticResource CarPartStyle}" Data="M 15,125 L 38,130 L 38,185 L 15,185 Z"/>
                            <Path x:Name="RearLeftDoorPart" Style="{StaticResource CarPartStyle}" Data="M 15,190 L 38,190 L 38,245 L 15,245 Z"/>
                            <Path x:Name="RearLeftFenderPart" Style="{StaticResource CarPartStyle}" Data="M 15,250 L 38,245 L 45,305 L 20,305 Z"/>

                            <Path x:Name="FrontRightFenderPart" Style="{StaticResource CarPartStyle}" Data="M 165,65 L 185,65 L 185,110 L 170,120 Z"/>
                            <Path x:Name="FrontRightDoorPart" Style="{StaticResource CarPartStyle}" Data="M 162,130 L 185,125 L 185,185 L 162,185 Z"/>
                            <Path x:Name="RearRightDoorPart" Style="{StaticResource CarPartStyle}" Data="M 162,190 L 185,190 L 185,245 L 162,245 Z"/>
                            <Path x:Name="RearRightFenderPart" Style="{StaticResource CarPartStyle}" Data="M 162,245 L 185,250 L 180,305 L 155,305 Z"/>

                            <Path x:Name="LeftSillPart" Style="{StaticResource CarPartStyle}" Data="M 8,125 L 14,125 L 14,245 L 8,245 Z"/>
                            <Path x:Name="RightSillPart" Style="{StaticResource CarPartStyle}" Data="M 186,125 L 192,125 L 192,245 L 186,245 Z"/>
                        </Canvas>
                    </StackPanel>

                    <StackPanel Margin="15" VerticalAlignment="Top">
                        <TextBlock Text="نمای جلو" Style="{StaticResource ViewTitleStyle}"/>
                        <Canvas Width="180" Height="150" Background="Transparent" Margin="0,0,0,20">
                            <Path x:Name="FrontViewHoodPart" Style="{StaticResource CarPartStyle}" Data="M 30,30 L 150,30 L 160,80 L 20,80 Z"/>
                            <Path x:Name="FrontViewBumperPart" Style="{StaticResource CarPartStyle}" Data="M 15,85 L 165,85 L 160,120 L 20,120 Z"/>
                            <Path x:Name="FrontViewRoofPart" Style="{StaticResource CarPartStyle}" Data="M 45,5 L 135,5 L 148,25 L 32,25 Z"/>
                            <Path x:Name="FrontPanelPart" Style="{StaticResource CarPartStyle}" Data="M 35,85 L 145,85 L 140,105 L 40,105 Z"/>
                            <Path x:Name="FrontViewLeftHeadlight" Style="{StaticResource CarPartStyle}" Fill="#FFFDE7" Data="M 20,85 L 50,85 L 45,100 L 22,95 Z"/>
                            <Path x:Name="FrontViewRightHeadlight" Style="{StaticResource CarPartStyle}" Fill="#FFFDE7" Data="M 130,85 L 160,85 L 158,95 L 135,100 Z"/>
                            <Path x:Name="FrontViewGrillePart" Style="{StaticResource CarPartStyle}" Fill="#334155" Data="M 55,87 L 125,87 L 120,110 L 60,110 Z"/>
                        </Canvas>

                        <TextBlock Text="نمای عقب" Style="{StaticResource ViewTitleStyle}"/>
                        <Canvas Width="180" Height="150" Background="Transparent">
                            <Path x:Name="RearViewTrunkPart" Style="{StaticResource CarPartStyle}" Data="M 30,40 L 150,40 L 160,90 L 20,90 Z"/>
                            <Path x:Name="RearViewBumperPart" Style="{StaticResource CarPartStyle}" Data="M 15,95 L 165,95 L 160,135 L 20,135 Z"/>
                            <Path x:Name="RearViewRoofPart" Style="{StaticResource CarPartStyle}" Data="M 45,10 L 135,10 L 146,35 L 34,35 Z"/>
                            <Path x:Name="RearPanelPart" Style="{StaticResource CarPartStyle}" Data="M 35,95 L 145,95 L 140,115 L 40,115 Z"/>
                            <Path x:Name="RearViewLeftTaillight" Style="{StaticResource CarPartStyle}" Fill="#EF4444" Data="M 20,95 L 55,95 L 50,110 L 22,105 Z"/>
                            <Path x:Name="RearViewRightTaillight" Style="{StaticResource CarPartStyle}" Fill="#EF4444" Data="M 125,95 L 160,95 L 158,105 L 130,110 Z"/>
                        </Canvas>
                    </StackPanel>

                    <StackPanel Margin="15">
                        <TextBlock Text="وضعیت شاسی‌ها و سینی" Style="{StaticResource ViewTitleStyle}"/>
                        <Canvas Width="160" Height="300" Background="Transparent">
                            <Rectangle x:Name="FrontLeftChassisPart" Width="20" Height="70" Canvas.Left="30" Canvas.Top="30" Style="{StaticResource CarPartStyle}"/>
                            <Rectangle x:Name="FrontRightChassisPart" Width="20" Height="70" Canvas.Left="110" Canvas.Top="30" Style="{StaticResource CarPartStyle}"/>
                            <Rectangle x:Name="RearLeftChassisPart" Width="20" Height="80" Canvas.Left="30" Canvas.Top="180" Style="{StaticResource CarPartStyle}"/>
                            <Rectangle x:Name="RearRightChassisPart" Width="20" Height="80" Canvas.Left="110" Canvas.Top="180" Style="{StaticResource CarPartStyle}"/>

                            <Line X1="40" Y1="100" X2="40" Y2="180" Stroke="#CBD5E1" StrokeThickness="4" StrokeDashArray="2 2"/>
                            <Line X1="120" Y1="100" X2="120" Y2="180" Stroke="#CBD5E1" StrokeThickness="4" StrokeDashArray="2 2"/>
                        </Canvas>
                    </StackPanel>

                </WrapPanel>
            </ScrollViewer>

            <Border Grid.Column="1" BorderBrush="#F1F5F9" BorderThickness="1,0,0,0" Padding="15,0,0,0" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="راهنمای وضعیت قطعات" FontSize="14" FontWeight="Bold" Foreground="#1C61E7" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Healthy}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="سالم" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Painted}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="رنگ شدگی" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Replaced}, Converter={StaticResource ResourceKey=StatusToBrushConverter}}"/>
                        <TextBlock Text="قطعه تعویضی" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.TouchUp}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="لیسه / آبرنگ" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Sunburned}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="آفتاب سوختگی" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.PDR}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="صافکاری بی رنگ" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Scratched}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="خط و خش" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Border Style="{StaticResource LegendCircleStyle}" Background="{Binding Source={x:Static models:BodyPartStatus.Damaged}, Converter={StaticResource StatusToBrushConverter}}"/>
                        <TextBlock Text="آسیب دیده / جوش" FontSize="12" Foreground="#475569" FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>