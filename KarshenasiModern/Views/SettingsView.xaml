<UserControl x:Class="KarshenasiModern.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="30">

        <StackPanel Width="500">

            <TextBlock Text="تنظیم دوربین ها"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="دوربین جلو"/>
            <ComboBox x:Name="FrontCameraBox"
                      Height="35"
                      Margin="0,5,0,15"/>

            <TextBlock Text="دوربین عقب"/>
            <ComboBox x:Name="RearCameraBox"
                      Height="35"
                      Margin="0,5,0,15"/>

            <TextBlock Text="دوربین چپ"/>
            <ComboBox x:Name="LeftCameraBox"
                      Height="35"
                      Margin="0,5,0,15"/>

            <TextBlock Text="دوربین راست"/>
            <ComboBox x:Name="RightCameraBox"
                      Height="35"
                      Margin="0,5,0,15"/>

            <Button x:Name="SaveButton"
                    Content="ذخیره تنظیمات"
                    Width="180"
                    Height="45"/>
        </StackPanel>

    </Grid>

</UserControl>