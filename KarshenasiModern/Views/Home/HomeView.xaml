<UserControl x:Class="KarshenasiModern.Views.Home.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="MainActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="320"/>
            <Setter Property="Height" Value="220"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="NormalShadow"
                                    Background="White"
                                    CornerRadius="18"
                                    Opacity="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" Opacity="0.15" Color="Black"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="HoverShadow"
                                    Background="White"
                                    CornerRadius="18"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30" Opacity="0.3" Color="#42A5F5"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="ButtonContentBorder"
                                    Background="White"
                                    CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverShadow" Property="Opacity" Value="1"/>
                                <Setter TargetName="NormalShadow" Property="Opacity" Value="0"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverShadow" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="NormalShadow" Property="Opacity" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F7FA">

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="کارشناسی مدرن"
                       FontSize="38"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="سیستم مدیریت کارشناسی خودرو"
                       Foreground="Gray"
                       FontSize="16"
                       Margin="0,10,0,40"
                       HorizontalAlignment="Center"/>

            <Border Background="White"
                    CornerRadius="15"
                    Padding="25"
                    Margin="15,0,15,30"
                    FlowDirection="RightToLeft">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      Opacity="0.1"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="کارشناسی امروز"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TodayCountText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="کل خودروها"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalCarsText"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="آخرین کارشناسی"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LastInspectionText"
                                   Text="-"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel HorizontalAlignment="Center">

                <Button x:Name="NewInspectionButton"
                        Style="{StaticResource MainActionButtonStyle}">

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚗"
                                   FontSize="56"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,15"/>

                        <TextBlock Text="کارشناسی جدید"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="10,0,10,10"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ArchiveButton"
                        Style="{StaticResource MainActionButtonStyle}">

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📂"
                                   FontSize="56"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,15"/>

                        <TextBlock Text="آرشیو کارشناسی ها"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="10,0,10,10"/>
                    </StackPanel>
                </Button>

                <Button x:Name="EditButton"
                        Style="{StaticResource MainActionButtonStyle}">

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="✏️"
                                   FontSize="56"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,15"/>

                        <TextBlock Text="ویرایش کارشناسی"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="10,0,10,10"/>
                    </StackPanel>
                </Button>

            </WrapPanel>

        </StackPanel>

    </Grid>
</UserControl>