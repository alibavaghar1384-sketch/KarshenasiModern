<UserControl x:Class="KarshenasiModern.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#F5F6FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="جستجو و مدیریت کارشناسی‌ها"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,25"
                   Foreground="#1C61E7"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="جستجوی هوشمند (نام مشتری، شاسی یا پلاک)" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#4A5568"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox"
                             Width="400"
                             Height="45"
                             VerticalContentAlignment="Center"
                             Padding="12,0"
                             FontSize="14"/>

                    <Button x:Name="SearchButton"
                            Content="جستجو"
                            Width="120"
                            Height="45"
                            Margin="10,0,0,0"
                            Background="#1C61E7"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border x:Name="DetailsBorder" 
                Grid.Row="2"
                Margin="0,0,0,20"
                Padding="20,15"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="CustomerText" Text="مشتری: -" Margin="0,0,30,0" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748"/>
                <TextBlock x:Name="PhoneText" Text="تلفن: -" Margin="0,0,30,0" FontSize="14" Foreground="#4A5568"/>
                <TextBlock x:Name="PlateText" Text="پلاک: -" Margin="0,0,30,0" FontSize="14" Foreground="#4A5568"/>
                <TextBlock x:Name="BrandText" Text="برند: -" Margin="0,0,30,0" FontSize="14" Foreground="#4A5568"/>
                <TextBlock x:Name="ModelText" Text="مدل: -" FontSize="14" Foreground="#4A5568"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="InspectionsGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E2E8F0"
                  RowHeight="45"
                  HeadersVisibility="Column"
                  FontSize="13">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#1A202C"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="10,0" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1C61E7"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="شناسه کارشناسی" Binding="{Binding Id}" Width="1.2*"/>
                <DataGridTextColumn Header="نام مشتری" Binding="{Binding Car.CustomerName}" Width="2*"/>
                <DataGridTextColumn Header="شماره شاسی خودرو" Binding="{Binding Car.ChassisNumber}" Width="2.5*"/>
                <DataGridTextColumn Header="تاریخ ثبت" Binding="{Binding CreatedAt}" Width="2*"/>
                <DataGridTextColumn Header="تعداد تصاویر" Binding="{Binding Photos.Count, Mode=OneWay}" Width="1.2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="LoadMoreButton"
                Grid.Row="4"
                Content="مشاهده موارد بیشتر..."
                Height="45"
                Margin="0,20,0,0"
                Background="#E2E8F0"
                Foreground="#1C61E7"
                FontWeight="Bold"
                FontSize="14"
                BorderThickness="0"
                Click="LoadMoreButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>